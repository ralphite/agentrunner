runs/
qa/blackbox-out*/
.env
acceptance-report.json
/agentrunner
/dist/
# .claude 本地态(settings.local 等)不入库,但项目共享的 skills 要入库
# (QA-0719:qa-remote-loop 流程沉淀,团队/future session 复用)。
.claude/*
!.claude/skills/
/runtime/
/ar
/bin/

# Vite build output — embedded into the Go binary at build time; never committed.
webui/frontend/dist/*
!webui/frontend/dist/.gitkeep

# Codex golden reference screenshots are intentionally TRACKED (parity ground truth;
# the ephemeral qa/runs/ and qa/blackbox-out/ captures are the ignored ones).
!qa/codex-reference/*.jpg
!qa/codex-reference/*.png
